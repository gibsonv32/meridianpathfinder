# MERIDIAN Environment Configuration
# Copy this to .env and update with your values

# API Configuration
API_HOST=127.0.0.1  # Use 0.0.0.0 for external access
API_PORT=8000
ENV=development  # development | production

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# LLM Configuration
ANTHROPIC_API_KEY=your-api-key-here
# OLLAMA_HOST=http://localhost:11434  # For Ollama

# Resource Limits
MAX_REQUEST_SIZE=100MB
REQUEST_TIMEOUT=300  # seconds
MAX_CONCURRENT_MODES=1  # Limit concurrent mode executions

# Data Directory (optional, defaults to ./data)
# DATA_DIR=/path/to/data

# Artifact Retention
ARTIFACT_RETENTION_DAYS=30