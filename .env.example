# =============================================================================
# MERIDIAN Environment Configuration (Self-Hosted / Secure by Default)
# =============================================================================
# Copy this to .env and update with your values
# IMPORTANT: chmod 600 .env after creating
#
# Access pattern: SSH tunnel from MacBook
#   ssh -L 3000:localhost:3000 -L 8000:localhost:8000 gibsonv32@spark-ad77
#   Then open: http://localhost:3000 (dashboard), http://localhost:8000/docs (API)
# =============================================================================

# =============================================================================
# API Configuration (localhost-only for security)
# =============================================================================
API_HOST=127.0.0.1  # Localhost only - access via SSH tunnel
API_PORT=8000
ENV=development  # development | production

# Logging
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# CORS - localhost only (SSH tunnel access pattern)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# =============================================================================
# LLM Configuration
# =============================================================================

# PRIMARY: SGLang gpt-oss-120b on DGX Spark
# For Docker bridge network, use host.docker.internal
OPENAI_API_BASE_URL=http://127.0.0.1:30000/v1
OPENAI_API_KEY=not-needed

# SECONDARY: Anthropic Claude Opus 4.5 for code generation (Mode 5)
# SECURITY: Never commit this file with real keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# Resource Limits
# =============================================================================
MAX_REQUEST_SIZE=100MB
REQUEST_TIMEOUT=300  # seconds
MAX_CONCURRENT_MODES=1  # Limit concurrent mode executions

# =============================================================================
# Data & Storage (DGX Spark paths)
# =============================================================================
DATA_DIR=/mnt/spark-data3/meridian
PROJECT_PATH=/home/gibsonv32/dev/meridian
ARTIFACT_RETENTION_DAYS=30

# =============================================================================
# Dashboard (for docker-compose) - localhost URLs for SSH tunnel access
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_PROJECT_PATH=/home/gibsonv32/dev/meridian