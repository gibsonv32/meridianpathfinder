# DGX Inference Stack - Environment Configuration
# Copy to .env and fill in your values:
#   cp env.template .env

# =============================================================================
# Required
# =============================================================================

# Anthropic API key for Claude access
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# Optional - Model Configuration
# =============================================================================

# Claude model (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# SGLang server URL (default: http://localhost:8000)
SGLANG_URL=http://localhost:8000

# =============================================================================
# Optional - HuggingFace
# =============================================================================

# HuggingFace token for gated models (if needed)
HF_TOKEN=

# HuggingFace cache directory
HF_HOME=~/.cache/huggingface

# =============================================================================
# Optional - Logging
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
