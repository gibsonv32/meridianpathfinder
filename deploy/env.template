# =============================================================================
# MERIDIAN DGX Deployment - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp deploy/env.template .env
# =============================================================================

# -----------------------------------------------------------------------------
# Required: Anthropic API Key (for Claude integration)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# LLM Provider Configuration
# -----------------------------------------------------------------------------
# Options: anthropic, dgx, ollama
LLM_PROVIDER=dgx

# DGX Model Endpoints (for LLM_PROVIDER=dgx)
DGX_HOST=localhost
DGX_FAST_PORT=30001
DGX_REASONING_PORT=30002

# Claude Model (for LLM_PROVIDER=anthropic or fallback)
CLAUDE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# API Server Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Request limits
REQUEST_TIMEOUT=300
MAX_CONCURRENT_MODES=1

# -----------------------------------------------------------------------------
# Dashboard Configuration
# -----------------------------------------------------------------------------
# These are used when building the dashboard Docker image
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_PROJECT_PATH=/app/workspace

# -----------------------------------------------------------------------------
# Data Paths (on DGX)
# -----------------------------------------------------------------------------
PROJECT_PATH=/home/gibsonv32/dev/meridian
ARTIFACT_PATH=/mnt/spark-data3/meridian/artifacts
DATA_PATH=/mnt/spark-data3/meridian/data
LOG_PATH=/mnt/spark-data3/meridian/logs

# -----------------------------------------------------------------------------
# Optional: HuggingFace Token (for gated models)
# -----------------------------------------------------------------------------
# HF_TOKEN=your-hf-token-here

# -----------------------------------------------------------------------------
# Optional: Feature Flags
# -----------------------------------------------------------------------------
# ENABLE_RAG=false
# ENABLE_CACHE=false
